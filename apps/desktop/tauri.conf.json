{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "My One Password",
  "version": "0.2.1",
  "identifier": "com.myonepassword.vault",
  "build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev --workspace=@my-one-password/web",
    "beforeBuildCommand": "npx cross-env VITE_API_BASE_URL=https://my-one-password-api.nalrarang.workers.dev/api npm run build --workspace=@my-one-password/web"
  },
  "app": {
    "windows": [
      {
        "title": "My One Password",
        "width": 960,
        "height": 700,
        "minWidth": 480,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://my-one-password-api.nalrarang.workers.dev; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; object-src 'none'; base-uri 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYxNjJEOUM5RUUwRkVBRDkKUldUWjZnL3V5ZGxpWVQxeEc3UHNURks5VGVvTm9EYUxKaGUxQld6anRkYllpcGN2R1duZjdsWHEK",
      "endpoints": [
        "https://github.com/Nalrarang/my-one-password-releases/releases/latest/download/latest.json"
      ]
    }
  }
}
